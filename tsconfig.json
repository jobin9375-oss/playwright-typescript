{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "strict": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "types": ["node", "playwright/test"], 
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["node_modules"]
}